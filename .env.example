# ============================================================
# Environment Variables — Intelligent Web Service Composition
# ============================================================
# Copy this file to .env and customise for your environment.
# Values shown below are the defaults used when the variable
# is not set.
# ============================================================

# ── Flask ───────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ── Upload limits ───────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

# ── Ollama / LLM ───────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Algorithm ───────────────────────────────────────────────
ALGORITHM_TIMEOUT=60

# ── SFT / Training ─────────────────────────────────────────
SFT_DEFAULT_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
# SFT_OUTPUT_DIR=          # auto-generated under backend/ if unset

# ── Security ────────────────────────────────────────────────
# Set API_KEY to require an X-API-Key header on every request
# (except /api/health). Leave blank/unset for open access (dev).
# API_KEY=your-secret-key-here
RATE_LIMIT_PER_MINUTE=120

# ── CORS ────────────────────────────────────────────────────
# Comma-separated origins, or * for all (dev only).
CORS_ORIGINS=*

# ── Gunicorn (production) ──────────────────────────────────
# GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=300
